BOT_API_PORT=9000

# custom cooldown for temporary voice channel generators per user cooldown, in milliseconds
APPLICATION_FEATURES_GENERATOR_COOLDOWN=3000

# find those values in the discord developer portal
DISCORD_APPLICATION_BOT_ID=
DISCORD_APPLICATION_TOKEN=
# PLAYING | LISTENING | WATCHING
DISCORD_ACTIVITY_TYPE=
DISCORD_ACTIVITY_TEXT=
# comma separated list of guild ids to which you wanna make the bot commands available, remove to allow commands in all guilds
DISCORD_COMMAND_GUILDS=
# comma separated list of guild ids to which you wanna make the bot whitelisted, remove to allow all guilds
DISCORD_WHITELISTED_GUILDS=

# path to the google credentials json file, see README.md for more info
GOOGLE_APPLICATION_CREDENTIALS=/etc/astro-bot/secrets/gcp-bigquery-creds.json

# if on kubernetes,
POD_ORDINAL=astro-0

SHARD_MANAGER_TOTAL_SHARDS=1
SHARD_MANAGER_TOTAL_PODS=1
SHARD_MANAGER_LOGIN_FACTOR=1

# Piper TTS service URL (for text-to-speech)
# When running with docker-compose, use the service name
PIPER_TTS_URL=http://piper-tts:8000